#!/usr/bin/env bash
# Reject commits that stage content looking like a session cookie,
# CSRF token, or third-party API secret. Scans STAGED content only --
# the working tree is irrelevant, so local debug files that stay
# unstaged cannot trigger this.
#
# LIMITATION: grep -E is line-oriented. A secret split across multiple
# lines (line continuations, pretty-printed JSON, base64 with embedded
# newlines) will not be detected here. Treat this hook as a fast-path
# guard, not a substitute for repo-wide secret scanning (gitleaks /
# trufflehog / GitHub push protection).
#
# Activate once per clone with:
#     git config core.hooksPath .githooks
set -euo pipefail

# Each pattern: regex | short label (shown on hit)
PATTERNS=(
    'session=eyJ[A-Za-z0-9_-]{20,}|Flask session cookie (signed, contains auth claim)'
    'minuspod_csrf=[A-Za-z0-9_-]{30,}|MinusPod CSRF token'
    'sk-ant-[A-Za-z0-9]{16,}|Anthropic API key'
    'sk-proj-[A-Za-z0-9]{16,}|OpenAI project key'
    'xoxb-[A-Za-z0-9-]{16,}|Slack bot token'
    'AIza[0-9A-Za-z_-]{30,}|Google API key'
    'ghp_[A-Za-z0-9]{30,}|GitHub personal access token'
    'AKIA[0-9A-Z]{16}|AWS access key ID'
    'Bearer [A-Za-z0-9._~+/=-]{32,}|HTTP Authorization header with long bearer'
)

# Binary files and large blobs: skip. Everything else: diff the staged
# version (":" prefix = index) and grep.
hit=0
while IFS= read -r path; do
    [ -z "$path" ] && continue
    # -d = detect binary via numstat; skip if --numstat shows - -
    if git diff --cached --numstat -- "$path" | awk '$1 == "-" && $2 == "-"' | grep -q .; then
        continue
    fi

    staged=$(git show ":$path" 2>/dev/null || true)
    [ -z "$staged" ] && continue

    for entry in "${PATTERNS[@]}"; do
        regex="${entry%|*}"
        label="${entry##*|}"
        # Filter doc/test placeholders out of matches before counting as a
        # hit. Real secrets won't contain these substrings; example payloads
        # in README/CHANGELOG/pattern fixtures regularly do.
        matches=$(printf '%s' "$staged" | grep -En -- "$regex" \
            | grep -Eiv 'example|placeholder|your-|fixture|sample|dummy|fake|redacted|xxxxx' \
            || true)
        if [ -n "$matches" ]; then
            echo "ERROR: $path appears to contain a $label"
            echo "       pattern: /$regex/"
            echo "       first match:"
            printf '%s\n' "$matches" | head -1 | sed 's/^/         /'
            hit=1
        fi
    done
done < <(git diff --cached --name-only --diff-filter=ACM)

# ASCII-only guard: block em-dashes, the star glyph, and smart quotes.
# Scope: everything staged EXCEPT CHANGELOG.md (frozen) and the
# benchmarks/llm/results/ tree (LLM-generated artifacts). Matches the
# CLAUDE.md "ASCII only" rule.
while IFS= read -r path; do
    [ -z "$path" ] && continue
    case "$path" in
        CHANGELOG.md|benchmarks/llm/results/*) continue ;;
    esac
    if git diff --cached --numstat -- "$path" | awk '$1 == "-" && $2 == "-"' | grep -q .; then
        continue
    fi
    bad=$(git show ":$path" 2>/dev/null | grep -nE $'[\xe2\x80\x94\xe2\x98\x85\xe2\x80\x98\xe2\x80\x99\xe2\x80\x9c\xe2\x80\x9d]' || true)
    if [ -n "$bad" ]; then
        echo "ERROR: $path contains non-ASCII glyph (em-dash, star, or smart quote)"
        printf '%s\n' "$bad" | head -3 | sed 's/^/         /'
        echo "       Use plain --, *, or straight quotes. See CLAUDE.md ASCII rule."
        hit=1
    fi
done < <(git diff --cached --name-only --diff-filter=ACM)

if [ $hit -ne 0 ]; then
    cat >&2 <<EOF

Commit blocked. One or more staged files contain text that looks like
a credential or a banned non-ASCII glyph. Options:

  1. If it's a real secret: unstage the file, scrub the value, rotate
     the credential upstream, then re-commit.
  2. If it's a false positive (e.g. a doc example or a detection
     pattern itself), bypass this hook with:
         git commit --no-verify
     -- but first double-check that the match really is benign.

EOF
    exit 1
fi
