# MinusPod — environment variables reference
#
# Coolify users: add these in the "Environment Variables" section of your
# Coolify application.  You do NOT need a .env file on the server — Coolify
# injects variables directly into the container.
#
# Self-hosted / local users: copy this file to .env and fill in your values.

# =============================================================================
# LLM Provider  (required — choose one option)
# =============================================================================

# --- Option 1: OpenRouter  (recommended) -----------------------------------
# Single API key gives access to 200+ models (Claude, GPT-4, Llama, Mistral…)
# Get a key at https://openrouter.ai/keys
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Override the default Claude Sonnet model used for ad detection:
# OPENAI_MODEL=anthropic/claude-sonnet-4-5

# --- Option 2: Anthropic API ------------------------------------------------
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Option 3: OpenAI-compatible endpoint (Ollama, local wrapper, etc.) ----
# LLM_PROVIDER=openai-compatible
# OPENAI_BASE_URL=http://your-ollama-host:11434/v1
# OPENAI_API_KEY=not-needed
# OPENAI_MODEL=qwen3:14b

# =============================================================================
# Whisper Transcription  (required — choose one option)
# =============================================================================

# --- Option 1: OpenRouter Whisper API  (recommended for Coolify) ------------
# Uses your OPENROUTER_API_KEY above — no GPU, no model download needed.
WHISPER_BACKEND=openrouter-api
WHISPER_API_MODEL=openai/whisper-large-v3-turbo

# --- Option 2: Groq Whisper API  (fast, generous free tier) -----------------
# WHISPER_BACKEND=openai-api
# WHISPER_API_BASE_URL=https://api.groq.com/openai/v1
# WHISPER_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WHISPER_API_MODEL=whisper-large-v3-turbo

# --- Option 3: OpenAI Whisper API -------------------------------------------
# WHISPER_BACKEND=openai-api
# WHISPER_API_BASE_URL=https://api.openai.com/v1
# WHISPER_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WHISPER_API_MODEL=whisper-1

# --- Option 4: Local Whisper  (GPU required) ---------------------------------
# Uncomment the `deploy.resources.reservations` block in docker-compose.yml too.
# WHISPER_BACKEND=local
# WHISPER_MODEL=small          # tiny | base | small | medium | large-v3
# WHISPER_DEVICE=cuda          # cuda | cpu

# =============================================================================
# Server
# =============================================================================

# Public URL Coolify assigns to this service (used for RSS feed URLs).
# In Coolify, set this to the domain you configured, e.g.:
BASE_URL=https://minuspod.yourdomain.com

# How long processed audio files are kept on disk (minutes).
# 1440 = 24 h.  Set to 0 to keep forever.
RETENTION_PERIOD=1440
